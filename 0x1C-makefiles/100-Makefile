CFLAGS=-Wall -Werror -Wextra -pedantic
CC=gcc
SRC=main.c school.c
OBJ=$(SRC:.c=.o)
NAME=school

.PHONY: all
all: $(NAME)

$(NAME): $(OBJ) m.h
	$(CC) $(OBJ) -o $(NAME)

.PHONY: clean
clean:
	$(RM) *~ $(NAME)

.PHONY: oclean
oclean:
	$(RM) $(OBJ)

.PHONY: fclean
fclean: clean oclean

.PHONY: re
re: fclean all